## Configuração de Produção para Hostinger
## Copie este arquivo como .env no servidor (manualmente ou após primeira implantação)
## Aviso: Atualizar valores conforme seu ambiente específico no Hostinger

APP_NAME="OctaBit ERP"
APP_ENV=production
APP_KEY=base64:GERAR_AUTOMATICAMENTE_COM_artisan_key:generate
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://octabit.tech/erp
ASSET_URL=https://octabit.tech/erp
APP_PORT=443

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database - Substituir com credenciais reais do Hostinger
# Dica: Criar banco de dados via cPanel antes do primeiro deploy
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u688664394_octaerp
DB_USERNAME=u688664394_octaerp
DB_PASSWORD=seu_senha_forte_aqui

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcast
BROADCAST_CONNECTION=log

# Filesystem
FILESYSTEM_DISK=local

# Queue - Usar database ou sync (Hostinger shared não tem celery)
QUEUE_CONNECTION=database

# Cache - File cache é suficiente para shared hosting
# Alternativas: redis (se disponível), memcached, file
CACHE_STORE=file
CACHE_PREFIX=octaerp_

# Redis (se disponível no Hostinger)
REDIS_CLIENT=phpredis
REDIS_HOST=localhost
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail - Usar SMTP do servidor ou serviço externo
# Opção 1: Log (teste apenas)
# MAIL_MAILER=log

# Opção 2: SMTP (recomendado para produção)
# Descobrir dados SMTP no painel Hostinger
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com.br
MAIL_PORT=587
MAIL_USERNAME=seu_email@octabit.tech
MAIL_PASSWORD=sua_senha_email
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@octabit.tech
MAIL_FROM_NAME="${APP_NAME}"

# API Integrations (se houver)
# EXTERNAL_API_KEY=

# Stripe (se usar pagamentos)
# STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=

# AWS S3 (se usar storage externo)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=

# Opcache
OPCACHE_VALIDATE_TIMESTAMPS=0
OPCACHE_ENABLE=1
OPCACHE_ENABLE_CLI=0

# Segurança
SECURE_COOKIES=true
HTTP_CLIENT_ALLOW_REDIRECTS=false

# Performance
APP_MAINTENANCE_DRIVER=file
